# ─── Application ──────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=3001
APP_NAME="Sears API"

# ─── API ──────────────────────────────────────────────────────────────────────
API_PREFIX=api
API_VERSION=1

# ─── CORS ─────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed origins
CORS_ORIGINS=http://localhost:3000

# ─── Swagger ──────────────────────────────────────────────────────────────────
SWAGGER_ENABLED=true
SWAGGER_PATH=api/docs
