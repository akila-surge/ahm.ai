# ─── Application ──────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=3001
APP_NAME="Sears API"

# ─── API ──────────────────────────────────────────────────────────────────────
API_PREFIX=api
API_VERSION=1

# ─── CORS ─────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed origins
CORS_ORIGINS=http://localhost:3000

# ─── Swagger ──────────────────────────────────────────────────────────────────
SWAGGER_ENABLED=true
SWAGGER_PATH=api/docs

# ─── Prevent Domain — External API Keys ──────────────────────────────────────
# SmartyStreets ZIP validation (API-SHS-01) — never expose to frontend
SMARTY_STREETS_API_KEY=
# searsconnection.com local offers (API-SC-09) — never expose to frontend
SEARS_CONNECTION_API_KEY=

# ─── Prevent Domain — External API Base URLs (override in prod if needed) ────
# SHS_GRAPHQL_URL=https://api.searshomeservices.com/graphql
# SEARS_CLEAN_API_URL=https://www.searsclean.com/api
# SEARS_CONNECTION_API_URL=https://www.searsconnection.com/api
# SMARTY_STREETS_API_URL=https://us-zipcode.api.smarty.com
